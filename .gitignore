# ── Python ──
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Virtual environments ──
.venv/
venv/
env/

# ── Environment / secrets ──
# Real env files hold credentials and must never be committed.
# Templates (.env.example) and non-secret dev defaults (frontend/.env.development) are kept.
.env
.env.local
.env.*.local

# ── Runtime logs / generated output ──
*.log
scheduling_platform/logs/
logs/

# ── Local runtime data (user conversations / uploaded knowledge, never commit) ──
scheduling_platform/data/sessions/
scheduling_platform/data/knowledge_uploads/
scheduling_platform/data/chroma/

# ── OS / editor ──
.DS_Store
.idea/
