# Dev data-layer config.
# API base URL + version prefix. Vite dev server proxies /api/v1 → :8000 backend.
VITE_API_BASE_URL=/api/v1
# `disabled` = hit the real backend (via Vite proxy); `enabled` = MSW mocks.
VITE_API_MOCKING=disabled
# Local development only; restart.sh injects the matching backend token.
VITE_PRIVILEGED_API_TOKEN=maestro-local-dev
