# ── LLM 配置（OpenAI 兼容接口）────────────────────────────────
# 默认以 DeepSeek 为例。切换供应商只需改这三项，代码无需改动：
#   OpenAI:    LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o-mini
#   通义千问:   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
#   本地 vLLM:  LLM_BASE_URL=http://localhost:8000/v1    LLM_MODEL=<served-model-name>
# LLM_API_KEY 留空时平台仍可运行（嵌入/LLM 不可用 → 路由降级为澄清；抽参走正则、解释走模板）。
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_API_KEY=

# ── Embedding 配置（意图路由第 1 层：嵌入语义路由）──────────────
# EMBED_MODEL 留空 → 嵌入路由禁用，路由直接走 LLM 分类层（平台照常运行）。
# 配上后，用户输入先做向量化与种子例句比相似度，命中即直接路由（更快、更稳）。
# DeepSeek 不提供 embeddings；可指向 OpenAI 或本地嵌入服务，例如：
#   OpenAI:    EMBED_BASE_URL=https://api.openai.com/v1  EMBED_MODEL=text-embedding-3-small
#   本地:      EMBED_BASE_URL=http://localhost:8001/v1   EMBED_MODEL=bge-m3
# EMBED_BASE_URL / EMBED_API_KEY 留空时回退复用上面的 LLM_BASE_URL / LLM_API_KEY。
EMBED_MODEL=
EMBED_BASE_URL=
EMBED_API_KEY=

# ── 路由与策略选择 ──────────────────────────────────────────
ROUTE_CONFIDENCE_THRESHOLD=0.8
EMBED_CONFIDENCE_THRESHOLD=0.72
STRATEGY_CONFIDENCE_THRESHOLD=0.7

# ── 事件层 ─────────────────────────────────────────────────
PATROL_INTERVAL_SECONDS=30
KITTING_LOOKAHEAD_DAYS=3

# ── 待确认动作 ─────────────────────────────────────────────
# 5 分钟内确认直接执行；超过 5 分钟重新校验；超过 24 小时过期。
PENDING_REVALIDATION_SECONDS=300
PENDING_EXPIRATION_SECONDS=86400

# ── Shell 执行输出 ─────────────────────────────────────────
# stdout/stderr 从进程启动起写入该目录；大输出只向 Agent 返回 output_ref。
# 默认留空时使用 MAESTRO_DATA_DIR/executions（未设置 MAESTRO_DATA_DIR 时为 ~/.maestro/executions）。
# EXECUTION_OUTPUT_DIR=

# ── Skill 脚本执行 ─────────────────────────────────────────
# Skill 导入后默认不可信；用户须信任当前 package hash，且每次脚本执行仍经过 ActionGate。
# SRT 可用时在沙箱执行；不可用时（如原生 Windows）仅在用户确认后于宿主机受控执行。
SKILL_SCRIPTS_ENABLED=true
SKILL_SCRIPT_TIMEOUT_SECONDS=15
SKILL_SCRIPT_MAX_OUTPUT_BYTES=65536
# SKILL_EXECUTION_DIR=

# ── 扩展管理与远程目录 ─────────────────────────────────────
# Web 部署必须设置强随机值；Electron 会在每次启动时自动生成并注入随机 Token。
PRIVILEGED_API_TOKEN=
# 可选，提高公开 GitHub API 限额；不会写入目录快照或审计日志。
GITHUB_TOKEN=
EXTENSION_CATALOG_SYNC_ENABLED=true
EXTENSION_CATALOG_SYNC_TIME=03:00
EXTENSION_CATALOG_SYNC_TIMEZONE=Asia/Shanghai
