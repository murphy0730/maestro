# OpenAI-compatible model configuration. Leave LLM_API_KEY empty to run in
# degraded mode without network model calls.
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_API_KEY=

# Runtime state root. The Runtime creates sessions-v3/, runs/, artifacts/ and
# runtime/journal.jsonl under this directory.
# MAESTRO_DATA_DIR=~/.maestro

# Browser frontend origins allowed by the FastAPI API.
# CORS_ALLOWED_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
